# ===== AnythingLLM 环境配置 =====
# 此文件会被挂载到容器内 /app/server/.env

# JWT 签名密钥（请修改为随机字符串）
JWT_SECRET=agentcug-jwt-secret-change-in-production-2025

# 存储目录
STORAGE_DIR=/app/server/storage

# ===== Qdrant 向量数据库 =====
VECTOR_DB=qdrant
QDRANT_ENDPOINT=http://qdrant:6333
QDRANT_API_KEY=

# ===== DeepSeek LLM =====
# 请填入你的 DeepSeek API Key
LLM_PROVIDER=deepseek
DeepSeekApiKey=sk-your-deepseek-api-key-here
DeepSeekModelPreference=deepseek-chat

# ===== Embedding 模型 =====
EMBEDDING_ENGINE=native
EmbeddingModelPref=BAAI/bge-m3

# ===== API Key（用于外部调用 AnythingLLM API）=====
# 设置后，Spring Boot 用这个 Key 调用 AnythingLLM
AUTH_TOKEN=agentcug-api-token-change-me