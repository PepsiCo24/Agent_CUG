# ============================================================
# Agent_CUG 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# WARNING: .env.example 是公开模板，禁止写入真实 API Key！
# ============================================================

# --- 项目基础 ---
PROJECT_NAME=Agent_CUG
DEBUG=true
LOG_LEVEL=INFO

# --- 域名（部署时修改） ---
DOMAIN_NAME=localhost

# --- LLM Provider（支持: mimo, openai, deepseek, qwen, claude） ---
MODEL_PROVIDER=mimo
LLM_API_KEY=your-api-key-here
LLM_API_BASE=https://token-plan-cn.xiaomimimo.com/v1
LLM_MODEL=mimo-v2.5-pro
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# --- Embedding Provider ---
EMBEDDING_PROVIDER=siliconflow
EMBEDDING_API_KEY=your-embedding-api-key-here
EMBEDDING_API_BASE=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3

# --- Chroma ---
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=agent_cug_docs

# --- SQLite ---
SQLITE_DB_PATH=./data/agent_cug.db

# --- Memory ---
MEMORY_SHORT_TERM_MAX=20
MEMORY_LONG_TERM_TTL_DAYS=90

# --- RAG ---
RAG_TOP_K=5
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_RERANK_ENABLED=true

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000