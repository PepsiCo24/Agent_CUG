# RAG Gateway Environment Variables
# Copy this file to .env and fill in your API keys

# SiliconFlow (Embedding BAAI/bge-m3)
EMBEDDING_API_KEY=your-siliconflow-api-key
EMBEDDING_BASE_URL=https://api.siliconflow.cn

# DeepSeek Chat
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# JWT Secret (for Spring Boot)
JWT_SECRET=your-jwt-secret-change-in-production

# Docling (optional, for advanced PDF parsing)
DOCLING_BASE_URL=http://localhost:5001
